MAILCLAW_ENV=development
MAILCLAW_HTTP_HOST=127.0.0.1
MAILCLAW_HTTP_PORT=3000
MAILCLAW_STATE_DIR=./state
MAILCLAW_SQLITE_PATH=./state/mailclaw.sqlite
MAILCLAW_RUNTIME_MODE=bridge
MAILCLAW_RUNTIME_COMMAND=

# Feature flags are off by default.
MAILCLAW_FEATURE_MAIL_INGEST=false
MAILCLAW_FEATURE_OPENCLAW_BRIDGE=false
MAILCLAW_FEATURE_SWARM_WORKERS=false
MAILCLAW_FEATURE_APPROVAL_GATE=false
MAILCLAW_FEATURE_IDENTITY_TRUST_GATE=false

# OpenClaw bridge settings.
MAILCLAW_OPENCLAW_BASE_URL=http://127.0.0.1:11437
MAILCLAW_OPENCLAW_AGENT_ID=mail
MAILCLAW_OPENCLAW_GATEWAY_TOKEN=change-me
MAILCLAW_OPENCLAW_SESSION_PREFIX=hook:mail

# Queue and orchestration limits.
MAILCLAW_QUEUE_MAX_CONCURRENT_ROOMS=3
MAILCLAW_QUEUE_MAX_WORKERS_PER_ROOM=3
MAILCLAW_QUEUE_MAX_GLOBAL_WORKERS=8

# Reporting cadence.
MAILCLAW_REPORTING_ACK_TIMEOUT_MS=8000
MAILCLAW_REPORTING_PROGRESS_INTERVAL_MS=60000

# Security policy defaults.
MAILCLAW_SECURITY_ALLOW_EMAILS=
MAILCLAW_SECURITY_ALLOW_DOMAINS=
MAILCLAW_SECURITY_DENY_EMAILS=
MAILCLAW_SECURITY_DENY_DOMAINS=
MAILCLAW_SECURITY_MAX_ATTACHMENTS=5
MAILCLAW_SECURITY_MAX_ATTACHMENT_BYTES=20971520
MAILCLAW_SECURITY_ALLOWED_MIME_TYPES=application/pdf,text/plain,image/png,image/jpeg

# Gmail OAuth login defaults for `mailctl login gmail` and `/api/auth/gmail/*`.
MAILCLAW_GMAIL_OAUTH_CLIENT_ID=
MAILCLAW_GMAIL_OAUTH_CLIENT_SECRET=
MAILCLAW_GMAIL_OAUTH_TOPIC_NAME=
MAILCLAW_GMAIL_OAUTH_USER_ID=me
MAILCLAW_GMAIL_OAUTH_LABEL_IDS=
MAILCLAW_GMAIL_OAUTH_SCOPES=
MAILCLAW_GMAIL_OAUTH_SESSION_TTL_MS=600000

# Outlook / Microsoft OAuth login defaults for `mailctl login outlook` and `/api/auth/outlook/*`.
MAILCLAW_MICROSOFT_OAUTH_CLIENT_ID=
MAILCLAW_MICROSOFT_OAUTH_CLIENT_SECRET=
MAILCLAW_MICROSOFT_OAUTH_TENANT=common
MAILCLAW_MICROSOFT_OAUTH_SCOPES=
MAILCLAW_MICROSOFT_OAUTH_SESSION_TTL_MS=600000
